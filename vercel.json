{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "outputDirectory": "public",
  "functions": {
    "api/handler.ts": {
      "maxDuration": 60,
      "includeFiles": "{dist/bootstrap-app.cjs,public/**}"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/api/(.*)",
      "dest": "/api/handler?__apiPath=$1"
    },
    {
      "src": "/health",
      "dest": "/api/handler?__apiPath=health"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

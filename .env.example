# ─── قاعدة البيانات ────────────────────────────────────────────────────────────
# PostgreSQL connection string — مطلوب ولا يعمل التطبيق بدونه
DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital_gl

# ─── جلسات المستخدم ──────────────────────────────────────────────────────────
# سر تشفير الجلسات — يجب أن يكون طويلاً وعشوائياً (64+ حرف)
# لتوليد واحد: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_secret_at_least_64_chars_long

# ─── البيئة ────────────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# ─── الخادم ────────────────────────────────────────────────────────────────────
# يمكن تركه فارغاً — الافتراضي 5000
PORT=5000

# ─── واجهة الويب (Vite) — اختياري ────────────────────────────────────────────
# إذا كان الـ frontend على نطاق آخر عن الـ API (مثل Vercel + خادم Node على VPS)،
# ضع أصل الـ API بدون شرطة أخيرة، مثل: https://api.example.com
# VITE_API_BASE_URL=
#
# ─── نشر Vercel (واجهة + API معاً) ───────────────────────────────────────────
# عند البناء على Vercel يُضبط VERCEL=1 تلقائياً: يُنسَخ dist/public إلى public/
# ويُشغَّل Express من src/index.ts (Fluid). اترك VITE_API_BASE_URL فارغاً لنفس النطاق.
# عيّن DATABASE_URL و SESSION_SECRET (إلزامي في production) في لوحة Vercel → Environment Variables.

# ─── Vercel (نشر موحّد: واجهة + API) ─────────────────────────────────────────
# عند النشر على Vercel: عيّن DATABASE_URL و SESSION_SECRET في لوحة المشروع (Production).
# المتغير VERCEL يُضبط تلقائياً على دالة /api — لا حاجة لـ VITE_API_BASE_URL إن كان كل شيء على نفس النطاق.

# ─── قاعدة البيانات ────────────────────────────────────────────────────────────
# PostgreSQL connection string — مطلوب ولا يعمل التطبيق بدونه
DATABASE_URL=postgresql://postgres:password@localhost:5432/hospital_gl

# ─── جلسات المستخدم ──────────────────────────────────────────────────────────
# سر تشفير الجلسات — يجب أن يكون طويلاً وعشوائياً (64+ حرف)
# لتوليد واحد: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_secret_at_least_64_chars_long

# ─── البيئة ────────────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# ─── الخادم ────────────────────────────────────────────────────────────────────
# يمكن تركه فارغاً — الافتراضي 5000
PORT=5000
